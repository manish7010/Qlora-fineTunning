# Groq API — required for eval_llm_judge.py
# Get your key at https://console.groq.com
GROQ_API_KEY=

# Groq model to use as LLM judge
GROQ_MODEL=llama-3.3-70b-versatile

# Hugging Face token — required to push the fine-tuned model to the Hub
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=
